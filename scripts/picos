#!/usr/bin/env bash
set -euo pipefail

# Praxo-PICOS Launch Script
# Starts all services and opens the dashboard

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PICOS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DATA_DIR="$HOME/Library/Application Support/Praxo-PICOS"
PIDS=()

cleanup() {
  echo ""
  echo "Shutting down Praxo-PICOS..."
  for pid in "${PIDS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait 2>/dev/null || true
  echo "All services stopped."
}
trap cleanup EXIT INT TERM

echo ""
echo "  Starting Praxo-PICOS..."
echo "  ───────────────────────"
echo ""

# --- Qdrant ---

QDRANT_BIN="$PICOS_ROOT/apps/desktop/vendor/qdrant"
if [ -f "$QDRANT_BIN" ]; then
  QDRANT_DIR="$DATA_DIR/qdrant"
  mkdir -p "$QDRANT_DIR/config" "$QDRANT_DIR/storage" "$QDRANT_DIR/snapshots"

  if [ ! -f "$QDRANT_DIR/config/config.yaml" ]; then
    cat > "$QDRANT_DIR/config/config.yaml" <<EOF
service:
  http_port: 6733
  grpc_port: 6734
storage:
  storage_path: $QDRANT_DIR/storage
  snapshots_path: $QDRANT_DIR/snapshots
telemetry_disabled: true
EOF
  fi

  echo "  [1/3] Starting Qdrant on port 6733..."
  "$QDRANT_BIN" --config-path "$QDRANT_DIR/config/config.yaml" --disable-telemetry > "$DATA_DIR/qdrant.log" 2>&1 &
  PIDS+=($!)
  sleep 2
else
  echo "  [1/3] Qdrant binary not found (vector search disabled)"
fi

# --- API ---

echo "  [2/3] Starting API on port 8865..."
cd "$PICOS_ROOT"
source .venv/bin/activate
PYTHONPATH="$PICOS_ROOT" uvicorn services.api.src.praxo_picos_api.main:app \
  --host 127.0.0.1 --port 8865 \
  > "$DATA_DIR/api.log" 2>&1 &
PIDS+=($!)

# --- Web ---

echo "  [3/3] Starting dashboard on port 3100..."
cd "$PICOS_ROOT/apps/web"
npm run dev > "$DATA_DIR/web.log" 2>&1 &
PIDS+=($!)

# --- Wait for services ---

echo ""
echo "  Waiting for services to start..."
sleep 5

API_OK=false
for i in 1 2 3 4 5; do
  if curl -sf http://127.0.0.1:8865/health > /dev/null 2>&1; then
    API_OK=true
    break
  fi
  sleep 2
done

if $API_OK; then
  echo "  ✓ API is running"
else
  echo "  ⚠ API may still be starting (check $DATA_DIR/api.log)"
fi

if curl -sf http://127.0.0.1:6733/healthz > /dev/null 2>&1; then
  echo "  ✓ Qdrant is running"
fi

if curl -sf http://127.0.0.1:3100 > /dev/null 2>&1; then
  echo "  ✓ Dashboard is running"
fi

# --- Open browser ---

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║       Praxo-PICOS is running!        ║"
echo "  ║                                      ║"
echo "  ║   Open: http://127.0.0.1:3100        ║"
echo "  ║                                      ║"
echo "  ║   Press Ctrl+C to stop               ║"
echo "  ╚══════════════════════════════════════╝"
echo ""

open "http://127.0.0.1:3100" 2>/dev/null || true

# --- Keep running ---

wait
